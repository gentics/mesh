{
	enNode: node(uuid: "c056aac6f22311f0a26100090ffe0001", lang: "en") {
		uuid
		language
		fields {
			... on folder {
				# [$.data.enNode.fields.nodeList.length()=0]
				nodeList {
					uuid
					language
					fields {
						... on folder {
							stringList(linkType: FULL)

							htmlList(linkType: FULL)
						}
					}
				}
				# [$.data.enNode.fields.nodeRef=<is-null>]
				nodeRef {
					uuid
					language
					fields {
						... on folder {
							stringList(linkType: FULL)

							htmlList(linkType: FULL)
						}
					}
				}
			}
		}
	}
}
# [$.errors=<is-undefined>]